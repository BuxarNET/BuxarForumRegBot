{
  "name": "XenForo",
  "domain": "xenforo.com",
  "engine": "xenforo",
  "detect": {
    "url_pattern": "register",
    "meta_tags": [
      {
        "name": "generator",
        "content": "XenForo"
      }
    ],
    "html_contains": [
      "xf-register"
    ]
  },
  "registration_page": {
    "url": [
      "/register",
      "/login/"
    ],
    "form_selector": [
      "form#register-form",
      "#pageLogin",
      [
        "#pageLogin"
      ]
    ]
  },
  "register_step": {
    "radio_selector": "input[name='register'][value='1']",
    "radio_value": "1"
  },
  "agree_step": {
    "checkboxes": [
      "#ctrl_pageLogin_remember"
    ],
    "submit_button": []
  },
  "fields": {
    "username": [
      "input[name='username']"
    ],
    "email": [
      "input[name='email']",
      "#ctrl_pageLogin_login"
    ],
    "password": [
      "input[name='password']",
      "#ctrl_pageLogin_password"
    ],
    "confirm_password": [
      "input[name='password_confirm']"
    ],
    "agree_checkbox": [
      "input[name='agree']"
    ],
    "submit_button": [
      "button[type='submit']"
    ],
    "captcha_indicator": [
      "iframe[src*='recaptcha']"
    ],
    "register_radio": [
      "#ctrl_pageLogin_not_registered"
    ],
    "register_radio_label": [
      "Нет, зарегистрироваться сейчас."
    ],
    "email_label": [
      "Ваше имя или e-mail:"
    ]
  },
  "custom_fields": [],
  "success_indicators": [
    "thank you for registering",
    "account has been created",
    "account created",
    "check your email",
    "activation link",
    "confirmation email"
  ],
  "error_indicators": [
    "username is already taken",
    "email already exists",
    "already taken",
    "already exists",
    "taken",
    "exists"
  ]
}